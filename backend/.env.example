# Server env (never commit real secrets)
#
# Database — Supabase Postgres only (no local Postgres in this repo).
# Dashboard → Connect → Database → URI. Use the database password (not the anon key).
# Add ?sslmode=require if the URI omits it. URL-encode @ and # in the password.
#
# • Direct (db.<ref>.supabase.co:5432) — OK if your network reaches Supabase over IPv6.
#
# • Session pooler — use on many IPv4-only networks when Direct is "not IPv4 compatible".
#   Choose "Session pooler", Type URI (pooler host, port 5432, user often postgres.<ref>).
#
# • Transaction pooler (6543) — avoid for alembic upgrade; prefer Session pooler.
#
DATABASE_URL=postgresql://postgres.REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
#
# Hybrid dev: API on host, Redis on host (brew / native install).
REDIS_URL=redis://localhost:6379/0
#
# Docker Compose: REDIS_URL is overridden to redis://redis:6379/0 for the api service.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_JWT_AUDIENCE=authenticated
WEBHOOK_SECRET=replace_with_long_random_secret

# AI providers (optional — MOCK_AI=true works offline)
MOCK_AI=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
DEEPGRAM_API_KEY=
SARVAM_API_KEY=
SARVAM_API_BASE=https://api.sarvam.ai/v1
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

WHATSAPP_PROVIDER=stub
INTERAKT_API_KEY=

LOG_LEVEL=INFO
